---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import SectionHeader from '../components/SectionHeader.astro';
import SectionDivider from '../components/SectionDivider.astro';
import InstagramFeed from '../components/InstagramFeed.astro';
import MapBanner from '../components/MapBanner.astro';
import Button from '../components/Button.astro';
import { url } from '../lib/url';
---

<BaseLayout title="Quem Somos">
  <Hero
    variant="page"
    eyebrow="// Dossiê"
    title="Quem Somos"
    subtitle="Estratégia, comunicação e controle do campo. Não somos os mais numerosos — somos os mais coesos."
    background={url('/gallery/ops-002.webp')}
  />

  <section class="mx-auto max-w-3xl px-6 py-20 text-center">
    <SectionHeader eyebrow="História" title="A origem do Control" align="center" />
    <div class="space-y-5 text-text-secondary leading-relaxed text-left md:text-center">
      <p>
        O <strong class="text-text-primary">CONTROL</strong> nasceu em
        <strong class="text-text-primary">2016</strong>, durante sessões de
        <strong class="text-text-primary">GTA Online</strong>, quando um grupo de amigos começou
        a jogar junto de forma organizada, estratégica e sempre priorizando trabalho em equipe.
      </p>
      <p>
        Com o tempo, esse grupo foi se fortalecendo, novos jogadores se juntaram e o que era
        apenas diversão virou um <strong class="text-text-primary">clã consolidado</strong>,
        baseado em amizade, disciplina e coordenação.
      </p>
      <p>
        Ao longo dessa trajetória, jogamos diversos títulos juntos, com destaque para
        <strong class="text-text-primary">Arma 3</strong>, até chegarmos ao nosso foco principal
        hoje: <strong class="text-text-primary">Squad</strong>, onde estratégia, comunicação e
        controle do campo fazem toda a diferença.
      </p>
      <p>
        Gostamos de jogar novos lançamentos em conjunto, manter a equipe unida e sempre evoluindo.
        <strong class="text-text-primary">Novos membros são bem-vindos</strong>, desde que
        compartilhem da nossa visão: jogar de forma organizada, coordenada e comprometida com o time.
      </p>
    </div>
  </section>

  <SectionDivider label="Presença" />

  <section class="mx-auto max-w-6xl px-6 py-12">
    <SectionHeader
      eyebrow="Mapa de operações"
      title="Presença global do clã"
      align="center"
    />
    <p class="mx-auto mb-8 max-w-2xl text-center text-text-secondary leading-relaxed">
      Operadores distribuídos pelo Brasil e parceiros em outros continentes. Clique no vídeo
      abaixo para visualizar a localização da unidade no mapa.
    </p>

    <MapBanner />

    <p class="mt-4 text-center font-mono text-[10px] uppercase tracking-widest text-text-muted">
      Hospedado no Google Maps · abre em nova aba
    </p>
  </section>

  <SectionDivider label="Instagram" />

  <section class="mx-auto max-w-6xl px-6 py-12">
    <SectionHeader
      eyebrow="@controlteam.br"
      title="Últimos posts no Instagram"
      align="center"
    />
    <p class="mx-auto mb-10 max-w-2xl text-center text-text-secondary leading-relaxed">
      Bastidores, registros operacionais e cobertura visual das nossas missões.
    </p>
    <InstagramFeed />
  </section>

  <section class="relative mt-12 border-y border-border-subtle bg-surface">
    <div class="grid-tactical-bg absolute inset-0 opacity-20" aria-hidden="true"></div>
    <div class="relative mx-auto flex max-w-4xl flex-col items-center gap-6 px-6 py-16 text-center">
      <span class="font-mono text-xs uppercase tracking-[0.4em] text-accent-tactical bracket-label">
        Recrutamento aberto
      </span>
      <h2 class="text-3xl md:text-5xl text-text-primary">
        Quer fazer parte da operação?
      </h2>
      <div class="mt-2 flex flex-wrap justify-center gap-4">
        <Button href={url('/recrutamento')} variant="primary" size="lg">Iniciar recrutamento</Button>
      </div>
    </div>
  </section>
</BaseLayout>
