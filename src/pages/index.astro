---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Button from '../components/Button.astro';
import SectionHeader from '../components/SectionHeader.astro';
import SectionDivider from '../components/SectionDivider.astro';
import ValueCard from '../components/ValueCard.astro';
import GameCard from '../components/GameCard.astro';
import OpsPanel from '../components/OpsPanel.astro';
import MapBanner from '../components/MapBanner.astro';
import InstagramFeed from '../components/InstagramFeed.astro';
import { site } from '../data/site';
import { getIcon } from '../lib/icons';
import { url } from '../lib/url';

const values = (await getCollection('values')).sort((a, b) => a.data.order - b.data.order);
const games = (await getCollection('games')).sort((a, b) => a.data.order - b.data.order);

const discordIconPath = 'M20.317 4.37a19.79 19.79 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028c.462-.63.873-1.295 1.226-1.994a.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.099.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z';
---

<BaseLayout>
  <Hero
    variant="home"
    eyebrow="Control Team"
    title="ESTRATÉGIA. COORDENAÇÃO. CONTROLE."
    subtitle={site.description}
    video={{ src: url('/video/hero.mp4'), poster: url('/video/hero-poster.jpg') }}
    overlayClass="bg-base/65"
  >
    <a
      slot="actions"
      href={site.social.discord}
      target="_blank"
      rel="noopener noreferrer"
      class="hero-discord-cta"
      aria-label="Entrar no Discord do Control Team"
    >
      <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d={discordIconPath}></path>
      </svg>
      <span>Entrar no Discord</span>
    </a>
    <Button slot="actions" href={url('/recrutamento')} variant="secondary" size="lg">
      Iniciar Recrutamento
    </Button>
  </Hero>

  <section class="mx-auto max-w-6xl px-6 py-20">
    <SectionHeader eyebrow="Modus Operandi" title="Quatro princípios. Uma operação." align="center" />
    <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-4">
      {
        values.map((v, i) => (
          <ValueCard title={v.data.title} index={i + 1} iconSvg={getIcon(v.data.icon)}>
            {v.body}
          </ValueCard>
        ))
      }
    </div>
  </section>

  <SectionDivider label="Operações" />

  <section class="mx-auto max-w-6xl px-6 py-12">
    <SectionHeader eyebrow="Frentes de combate" title="Jogos cobertos pelo clã" align="center" />
    <div class="grid gap-6 md:grid-cols-2">
      {
        games.map((g) => (
          <GameCard name={g.data.name} tagline={g.data.tagline} cover={url(g.data.cover)}>
            {g.body}
          </GameCard>
        ))
      }
    </div>
  </section>

  <SectionDivider label="Presença" />

  <section class="mx-auto max-w-6xl px-6 py-12">
    <SectionHeader eyebrow="Mapa de operações" title="Presença global do clã" align="center" />
    <p class="mx-auto mb-8 max-w-2xl text-center text-text-secondary leading-relaxed">
      Operadores distribuídos pelo Brasil e parceiros em outros continentes. Clique no vídeo
      abaixo para visualizar a localização da unidade no mapa.
    </p>
    <MapBanner />
    <p class="mt-4 text-center font-mono text-[10px] uppercase tracking-widest text-text-muted">
      Hospedado no Google Maps · abre em nova aba
    </p>
  </section>

  <SectionDivider label="Status" />

  <section class="mx-auto max-w-6xl px-6 py-12">
    <SectionHeader eyebrow="Painel de Operações" title="Estado atual da unidade" align="center" />
    <OpsPanel />
  </section>

  <SectionDivider label="Comunidade" />

  <section class="mx-auto max-w-6xl px-6 py-12">
    <SectionHeader eyebrow="Discord" title="Entre na sala de operações" align="center" />
    <div class="grid items-center gap-10 md:grid-cols-2">
      <div class="space-y-5 text-center md:text-left">
        <p class="text-text-secondary leading-relaxed">
          Toda comunicação, briefing e debrief acontece no nosso Discord. Veja quem está em
          operação agora mesmo e entre direto pelo widget ao lado — sem cadastro, sem fricção.
        </p>
        <ul class="space-y-2 font-mono text-[11px] uppercase tracking-widest text-text-secondary">
          <li class="flex items-center justify-center gap-3 md:justify-start">
            <span class="inline-block h-1.5 w-1.5 rounded-full bg-accent-tactical"></span>
            Canais de voz por operação
          </li>
          <li class="flex items-center justify-center gap-3 md:justify-start">
            <span class="inline-block h-1.5 w-1.5 rounded-full bg-accent-tactical"></span>
            Anúncios de eventos e treinos
          </li>
          <li class="flex items-center justify-center gap-3 md:justify-start">
            <span class="inline-block h-1.5 w-1.5 rounded-full bg-accent-tactical"></span>
            Atendimento a recrutas
          </li>
        </ul>
        <div class="flex flex-wrap justify-center gap-3 pt-2 md:justify-start">
          <a
            href={site.social.discord}
            target="_blank"
            rel="noopener noreferrer"
            class="hero-discord-cta hero-discord-cta--md"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d={discordIconPath}></path>
            </svg>
            Entrar no Discord
          </a>
        </div>
      </div>
      <div class="flex justify-center md:justify-end">
        <div class="border border-border-subtle bg-surface p-2">
          <iframe
            src="https://discord.com/widget?id=253873258196238336&theme=dark"
            width="350"
            height="500"
            allowtransparency="true"
            frameborder="0"
            sandbox="allow-popups allow-popups-to-escape-sandbox allow-same-origin allow-scripts"
            title="Discord — Control Team"
            loading="lazy"
            class="block"
          ></iframe>
        </div>
      </div>
    </div>
  </section>

  <SectionDivider label="Instagram" />

  <section class="mx-auto max-w-6xl px-6 py-12">
    <SectionHeader eyebrow="@controlteam.br" title="Últimos posts no Instagram" align="center" />
    <p class="mx-auto mb-10 max-w-2xl text-center text-text-secondary leading-relaxed">
      Bastidores, registros operacionais e cobertura visual das nossas missões.
    </p>
    <InstagramFeed />
  </section>

  <section class="relative mt-20 border-y border-border-subtle bg-surface">
    <div class="grid-tactical-bg absolute inset-0 opacity-20" aria-hidden="true"></div>
    <div class="relative mx-auto flex max-w-4xl flex-col items-center gap-6 px-6 py-20 text-center">
      <span class="font-mono text-xs uppercase tracking-[0.4em] text-accent-tactical bracket-label">
        Recrutamento aberto
      </span>
      <h2 class="text-4xl md:text-6xl text-text-primary">
        Pronto para operar com disciplina?
      </h2>
      <p class="max-w-2xl text-text-secondary">
        Selecionamos por compromisso, não por quantidade. Se você busca jogabilidade séria,
        comunicação eficiente e operações coordenadas, este é o seu posto.
      </p>
      <div class="mt-2 flex flex-wrap justify-center gap-4">
        <a
          href={site.social.discord}
          target="_blank"
          rel="noopener noreferrer"
          class="hero-discord-cta"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d={discordIconPath}></path>
          </svg>
          Entrar no Discord
        </a>
        <Button href={url('/recrutamento')} variant="secondary" size="lg">Iniciar Inscrição</Button>
      </div>
    </div>
  </section>
</BaseLayout>

<style is:global>
  .hero-discord-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    padding: 0.95rem 1.6rem;
    border-radius: 2px;
    background: var(--color-accent-tactical, #8fad3a);
    color: var(--color-base, #0a0d10);
    font-family: var(--font-display, 'Rajdhani', sans-serif);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    font-size: 1rem;
    text-decoration: none;
    border: 1px solid var(--color-accent-tactical);
    transition: transform 0.18s ease, box-shadow 0.2s ease, background 0.2s ease;
    box-shadow: 0 0 18px rgba(140, 198, 63, 0.45);
    animation: hero-discord-pulse 2.4s ease-in-out infinite;
  }
  .hero-discord-cta--md {
    padding: 0.65rem 1.2rem;
    font-size: 0.875rem;
  }
  .hero-discord-cta:hover {
    background: var(--color-accent-tactical-dim, #6e8a22);
    border-color: var(--color-accent-tactical-dim, #6e8a22);
    transform: translateY(-1px);
    box-shadow: 0 0 28px rgba(140, 198, 63, 0.7);
  }
  @keyframes hero-discord-pulse {
    0%, 100% { box-shadow: 0 0 16px rgba(140, 198, 63, 0.45); }
    50% { box-shadow: 0 0 28px rgba(140, 198, 63, 0.75); }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-discord-cta { animation: none; }
  }
</style>
