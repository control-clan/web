---
import { url } from '../lib/url';

interface VideoBackground {
  src: string;
  poster: string;
}

interface Props {
  variant?: 'home' | 'page';
  eyebrow?: string;
  title: string;
  subtitle?: string;
  background?: string;
  video?: VideoBackground;
  overlayClass?: string;
  /** Se true, esconde o logo CTRL no hero (default false — logo aparece em TODAS as páginas). */
  hideLogo?: boolean;
}

const {
  variant = 'page',
  eyebrow,
  title,
  subtitle,
  background,
  video,
  overlayClass = 'bg-base/70',
  hideLogo = false,
} = Astro.props;
const isHome = variant === 'home';
const heightClass = isHome ? 'min-h-[88vh]' : 'min-h-[44vh]';
---

<section
  class={`relative flex ${heightClass} items-center justify-center overflow-hidden border-b border-border-subtle text-center`}
>
  {
    video && (
      <div class="absolute inset-0">
        <video
          class="h-full w-full object-cover"
          src={video.src}
          poster={video.poster}
          autoplay
          muted
          loop
          playsinline
          preload="metadata"
          aria-hidden="true"
        />
        <div class={`absolute inset-0 ${overlayClass}`}></div>
        <div class="absolute inset-0 bg-gradient-to-t from-base via-base/40 to-base/20"></div>
      </div>
    )
  }
  {
    !video && background && (
      <div class="absolute inset-0">
        <div
          class="absolute inset-0 bg-cover bg-center"
          style={`background-image: url('${background}')`}
          aria-hidden="true"
        >
        </div>
        <div class={`absolute inset-0 ${overlayClass}`}></div>
        <div class="absolute inset-0 bg-gradient-to-t from-base via-base/50 to-base/30"></div>
      </div>
    )
  }
  <div class="grid-tactical-bg absolute inset-0 opacity-20"></div>

  <div class="relative z-10 mx-auto flex w-full max-w-7xl flex-col items-center px-6">
    {
      !hideLogo && (
        <img
          src={url('/brand/logo-ctrl.webp')}
          alt="Control Team"
          width={isHome ? 160 : 96}
          height={isHome ? 160 : 96}
          class={`mb-6 ${isHome ? 'h-28 w-28 md:h-36 md:w-36 lg:h-40 lg:w-40' : 'h-16 w-16 md:h-20 md:w-20'} drop-shadow-[0_0_24px_rgba(140,198,63,0.35)]`}
        />
      )
    }
    {
      eyebrow && (
        <span class="font-mono text-xs uppercase tracking-[0.4em] text-accent-tactical bracket-label">
          {eyebrow}
        </span>
      )
    }
    <h1
      class={`mt-4 leading-[0.95] text-text-primary whitespace-nowrap ${isHome ? 'hero-title-home' : 'hero-title-page'}`}
    >
      {title}
    </h1>
    {
      subtitle && (
        <p class="mt-6 max-w-2xl text-base md:text-lg leading-relaxed text-text-secondary">
          {subtitle}
        </p>
      )
    }
    {
      isHome && (
        <div class="mt-10 flex flex-wrap items-center justify-center gap-4">
          <slot name="actions" />
        </div>
      )
    }
  </div>

  {
    isHome && (
      <div class="absolute bottom-6 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-text-muted">
        <span class="font-mono text-[10px] uppercase tracking-[0.3em]">Avançar</span>
        <div class="h-8 w-px bg-accent-tactical/60 animate-pulse"></div>
      </div>
    )
  }
</section>

<style>
  /* Tipografia fluida — garante 1 linha em qualquer viewport sem overflow */
  .hero-title-home {
    font-family: var(--font-display);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.005em;
    /* clamp(min, fluido, max) — escala com largura da viewport */
    font-size: clamp(1.5rem, 6.6vw, 6rem);
  }
  .hero-title-page {
    font-family: var(--font-display);
    font-weight: 700;
    text-transform: uppercase;
    font-size: clamp(1.75rem, 7vw, 4.5rem);
  }

  /* Em telas muito estreitas, permite quebra para evitar overflow horrendo */
  @media (max-width: 360px) {
    .hero-title-home, .hero-title-page {
      white-space: normal;
      font-size: clamp(1.25rem, 9vw, 2.25rem);
    }
  }
</style>
