---
import { site } from '../data/site';
import { url } from '../lib/url';
import Button from './Button.astro';

const currentPath = Astro.url.pathname;
const homeHref = url('/');
const isActive = (href: string) => {
  const target = url(href);
  return href === '/' ? currentPath === homeHref : currentPath.startsWith(target);
};
---

<header class="sticky top-0 z-50 border-b border-border-subtle bg-base/85 backdrop-blur-md">
  <div class="mx-auto flex h-16 max-w-6xl items-center justify-between px-6">
    <a href={homeHref} class="group flex items-center gap-3" aria-label="Control Team — Início">
      <img
        src={url('/brand/logo-ctrl.webp')}
        alt=""
        width="36"
        height="36"
        class="h-9 w-9 transition-transform group-hover:scale-105"
        aria-hidden="true"
      />
      <span
        class="font-display text-2xl font-bold tracking-widest text-text-primary transition-colors group-hover:text-accent-tactical"
      >
        CTRL
      </span>
      <span class="hidden font-mono text-[10px] uppercase tracking-[0.3em] text-text-muted md:inline">
        // CONTROL TEAM
      </span>
    </a>

    <nav class="hidden md:block" aria-label="Principal">
      <ul class="flex items-center gap-8">
        {
          site.nav.map((item) => (
            <li>
              <a
                href={url(item.href)}
                class:list={[
                  'font-display text-sm uppercase tracking-wider transition-colors',
                  isActive(item.href)
                    ? 'text-accent-tactical'
                    : 'text-text-secondary hover:text-text-primary',
                ]}
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <Button href={site.social.discord} variant="primary" size="md" external class="hidden md:inline-flex">
      Discord
    </Button>

    <button
      type="button"
      id="nav-toggle"
      class="md:hidden inline-flex h-10 w-10 items-center justify-center text-text-primary"
      aria-controls="mobile-nav"
      aria-expanded="false"
      aria-label="Abrir menu"
    >
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M3 6h18M3 12h18M3 18h18" stroke-linecap="square" />
      </svg>
    </button>
  </div>

  <div
    id="mobile-nav"
    class="hidden border-t border-border-subtle bg-base md:hidden"
  >
    <ul class="flex flex-col px-6 py-4">
      {
        site.nav.map((item) => (
          <li>
            <a
              href={url(item.href)}
              class:list={[
                'block py-3 font-display text-sm uppercase tracking-wider transition-colors',
                isActive(item.href)
                  ? 'text-accent-tactical'
                  : 'text-text-secondary hover:text-text-primary',
              ]}
            >
              {item.label}
            </a>
          </li>
        ))
      }
      <li class="mt-2">
        <Button href={site.social.discord} variant="primary" size="md" external class="w-full">
          Discord
        </Button>
      </li>
    </ul>
  </div>
</header>

<script>
  const toggle = document.getElementById('nav-toggle');
  const menu = document.getElementById('mobile-nav');
  toggle?.addEventListener('click', () => {
    const isOpen = menu?.classList.toggle('hidden') === false;
    toggle.setAttribute('aria-expanded', String(isOpen));
    toggle.setAttribute('aria-label', isOpen ? 'Fechar menu' : 'Abrir menu');
  });
</script>
