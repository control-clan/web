---
import { site } from '../data/site';
import { url } from '../lib/url';

const currentPath = Astro.url.pathname;
const homeHref = url('/');
const isActive = (href: string) => {
  const target = url(href);
  return href === '/' ? currentPath === homeHref : currentPath.startsWith(target);
};
---

<header class="sticky top-0 z-50 border-b border-border-subtle bg-base/85 backdrop-blur-md">
  <div class="mx-auto flex h-16 max-w-6xl items-center justify-between px-6">
    <a href={homeHref} class="group flex items-center gap-3" aria-label="Control Team — Início">
      <img
        src={url('/brand/logo-ctrl.webp')}
        alt=""
        width="48"
        height="48"
        class="h-12 w-12 transition-transform group-hover:scale-105"
        aria-hidden="true"
      />
      <span
        class="font-display text-2xl font-bold tracking-widest text-text-primary transition-colors group-hover:text-accent-tactical"
      >
        CTRL
      </span>
      <span class="hidden font-mono text-[10px] uppercase tracking-[0.3em] text-text-muted md:inline">
        // CONTROL TEAM
      </span>
    </a>

    <nav class="hidden md:block" aria-label="Principal">
      <ul class="flex items-center gap-8">
        {
          site.nav.map((item) => (
            <li>
              <a
                href={url(item.href)}
                class:list={[
                  'font-display text-sm uppercase tracking-wider transition-colors',
                  isActive(item.href)
                    ? 'text-accent-tactical'
                    : 'text-text-secondary hover:text-text-primary',
                ]}
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <a
      href={site.social.discord}
      target="_blank"
      rel="noopener noreferrer"
      class="header-discord hidden md:inline-flex items-center gap-2 rounded-[2px] border border-accent-tactical bg-accent-tactical px-5 py-2.5 font-display text-sm font-semibold uppercase tracking-wider text-base shadow-[0_0_18px_rgba(140,198,63,0.45)] transition-all hover:bg-accent-tactical-dim hover:border-accent-tactical-dim"
      aria-label="Entrar no Discord do Control Team"
    >
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M20.317 4.37a19.79 19.79 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028c.462-.63.873-1.295 1.226-1.994a.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.099.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/>
      </svg>
      <span>Discord</span>
    </a>

    <button
      type="button"
      id="nav-toggle"
      class="md:hidden inline-flex h-10 w-10 items-center justify-center text-text-primary"
      aria-controls="mobile-nav"
      aria-expanded="false"
      aria-label="Abrir menu"
    >
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M3 6h18M3 12h18M3 18h18" stroke-linecap="square" />
      </svg>
    </button>
  </div>

  <div
    id="mobile-nav"
    class="hidden border-t border-border-subtle bg-base md:hidden"
  >
    <ul class="flex flex-col px-6 py-4">
      {
        site.nav.map((item) => (
          <li>
            <a
              href={url(item.href)}
              class:list={[
                'block py-3 font-display text-sm uppercase tracking-wider transition-colors',
                isActive(item.href)
                  ? 'text-accent-tactical'
                  : 'text-text-secondary hover:text-text-primary',
              ]}
            >
              {item.label}
            </a>
          </li>
        ))
      }
      <li class="mt-2">
        <a
          href={site.social.discord}
          target="_blank"
          rel="noopener noreferrer"
          class="flex w-full items-center justify-center gap-2 rounded-[2px] border border-accent-tactical bg-accent-tactical px-5 py-3 font-display text-sm font-semibold uppercase tracking-wider text-base"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M20.317 4.37a19.79 19.79 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028c.462-.63.873-1.295 1.226-1.994a.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.099.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/>
          </svg>
          Acessar Discord
        </a>
      </li>
    </ul>
  </div>
</header>

<style>
  .header-discord {
    animation: pulse-glow 2.4s ease-in-out infinite;
  }
  @keyframes pulse-glow {
    0%, 100% { box-shadow: 0 0 16px rgba(140, 198, 63, 0.35); }
    50% { box-shadow: 0 0 26px rgba(140, 198, 63, 0.7); }
  }
  @media (prefers-reduced-motion: reduce) {
    .header-discord { animation: none; }
  }
</style>

<script>
  const toggle = document.getElementById('nav-toggle');
  const menu = document.getElementById('mobile-nav');
  toggle?.addEventListener('click', () => {
    const isOpen = menu?.classList.toggle('hidden') === false;
    toggle.setAttribute('aria-expanded', String(isOpen));
    toggle.setAttribute('aria-label', isOpen ? 'Fechar menu' : 'Abrir menu');
  });
</script>
