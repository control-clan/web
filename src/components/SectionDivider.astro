---
interface Props {
  label?: string;
}

const { label } = Astro.props;
---

<div class="my-16 flex items-center gap-4 text-accent-tactical/60">
  <div class="h-px flex-1 bg-border-subtle"></div>
  {
    label && (
      <span class="font-mono text-[10px] uppercase tracking-[0.4em] bracket-label">
        {label}
      </span>
    )
  }
  <div class="h-px flex-1 bg-border-subtle"></div>
</div>
