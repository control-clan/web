---
// Background tático global — grid digital + partículas verdes + linhas de conexão
// + glow sutil no mouse. Performance: requestAnimationFrame, pausa quando aba oculta,
// densidade reduzida em mobile, respeita prefers-reduced-motion.
---

<div
  id="global-bg"
  aria-hidden="true"
  class="pointer-events-none fixed inset-0 -z-10 select-none"
>
  <div class="global-bg__grid"></div>
  <canvas id="global-bg-canvas" class="global-bg__canvas"></canvas>
  <div class="global-bg__radar" aria-hidden="true"></div>
  <div class="global-bg__vignette"></div>
</div>

<style>
  #global-bg {
    background-color: #050808;
    overflow: hidden;
  }

  /* Grid digital sutil */
  .global-bg__grid {
    position: absolute;
    inset: -1px;
    background-image:
      linear-gradient(to right, rgba(140, 198, 63, 0.06) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(140, 198, 63, 0.06) 1px, transparent 1px);
    background-size: 56px 56px;
    mask-image: radial-gradient(ellipse at center, rgba(0, 0, 0, 0.85) 0%, rgba(0, 0, 0, 0.5) 60%, transparent 100%);
    -webkit-mask-image: radial-gradient(ellipse at center, rgba(0, 0, 0, 0.85) 0%, rgba(0, 0, 0, 0.5) 60%, transparent 100%);
  }

  .global-bg__canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
  }

  /* Sweep tipo radar — bem sutil, lento */
  .global-bg__radar {
    position: absolute;
    inset: -20%;
    background:
      radial-gradient(
        circle at 50% 50%,
        rgba(140, 198, 63, 0.045) 0%,
        rgba(140, 198, 63, 0.02) 22%,
        transparent 45%
      );
    animation: radar-sweep 18s linear infinite;
    transform-origin: 50% 50%;
    will-change: transform;
  }

  @keyframes radar-sweep {
    from { transform: rotate(0deg); }
    to   { transform: rotate(360deg); }
  }

  /* Vinheta para garantir contraste no conteúdo central */
  .global-bg__vignette {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at center, transparent 0%, transparent 55%, rgba(5, 8, 8, 0.55) 100%),
      linear-gradient(to bottom, rgba(5, 8, 8, 0.0) 0%, rgba(5, 8, 8, 0.35) 100%);
  }

  @media (max-width: 640px) {
    .global-bg__grid { background-size: 40px 40px; }
    .global-bg__radar { animation-duration: 28s; }
  }

  @media (prefers-reduced-motion: reduce) {
    .global-bg__radar { animation: none; }
  }
</style>

<script is:inline>
  (function () {
    const canvas = document.getElementById('global-bg-canvas');
    if (!canvas) return;
    const ctx = canvas.getContext('2d', { alpha: true });
    if (!ctx) return;

    const reduceMotion =
      window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    const isCoarsePointer =
      window.matchMedia && window.matchMedia('(pointer: coarse)').matches;

    let dpr = Math.min(window.devicePixelRatio || 1, 2);
    let width = 0;
    let height = 0;

    const COLOR_PARTICLE = 'rgba(140, 198, 63, 0.85)';
    const COLOR_PARTICLE_DIM = 'rgba(140, 198, 63, 0.55)';
    const COLOR_LINK = 'rgba(140, 198, 63, ';
    const COLOR_GLOW = 'rgba(140, 198, 63, ';

    let targetCount = 0;
    const particles = [];
    const mouse = { x: -9999, y: -9999, active: false };
    let lastFrame = 0;
    let running = true;

    function resize() {
      width = canvas.clientWidth = window.innerWidth;
      height = canvas.clientHeight = window.innerHeight;
      dpr = Math.min(window.devicePixelRatio || 1, 2);
      canvas.width = Math.floor(width * dpr);
      canvas.height = Math.floor(height * dpr);
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      // densidade: ~1 partícula por 18000 px², limitado
      const area = width * height;
      const isMobile = width < 720;
      const density = isMobile ? 26000 : 18000;
      targetCount = Math.max(12, Math.min(isMobile ? 28 : 70, Math.floor(area / density)));
      adjustParticles();
    }

    function rand(min, max) {
      return Math.random() * (max - min) + min;
    }

    function makeParticle() {
      return {
        x: rand(0, width),
        y: rand(0, height),
        vx: rand(-0.18, 0.18),
        vy: rand(-0.18, 0.18),
        r: rand(0.6, 1.6),
      };
    }

    function adjustParticles() {
      while (particles.length < targetCount) particles.push(makeParticle());
      if (particles.length > targetCount) particles.length = targetCount;
    }

    function step(now) {
      if (!running) return;
      const delta = Math.min(64, now - lastFrame || 16);
      lastFrame = now;

      ctx.clearRect(0, 0, width, height);

      // partículas
      const linkDist = width < 720 ? 110 : 140;
      const linkDist2 = linkDist * linkDist;

      for (let i = 0; i < particles.length; i++) {
        const p = particles[i];
        // movimento
        p.x += p.vx * (delta / 16);
        p.y += p.vy * (delta / 16);

        // bordas (wrap)
        if (p.x < -10) p.x = width + 10;
        if (p.x > width + 10) p.x = -10;
        if (p.y < -10) p.y = height + 10;
        if (p.y > height + 10) p.y = -10;

        // leve atração ao mouse
        if (mouse.active) {
          const dx = mouse.x - p.x;
          const dy = mouse.y - p.y;
          const d2 = dx * dx + dy * dy;
          if (d2 < 26000) {
            const f = 0.0006 / Math.max(0.5, Math.sqrt(d2) / 60);
            p.vx += dx * f;
            p.vy += dy * f;
          }
        }

        // amortecimento
        p.vx *= 0.992;
        p.vy *= 0.992;

        // desenha partícula
        ctx.beginPath();
        ctx.fillStyle = COLOR_PARTICLE;
        ctx.shadowBlur = 6;
        ctx.shadowColor = COLOR_PARTICLE_DIM;
        ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
        ctx.fill();
      }
      ctx.shadowBlur = 0;

      // linhas de conexão (sem reduce-motion)
      if (!reduceMotion) {
        for (let i = 0; i < particles.length; i++) {
          const a = particles[i];
          for (let j = i + 1; j < particles.length; j++) {
            const b = particles[j];
            const dx = a.x - b.x;
            const dy = a.y - b.y;
            const d2 = dx * dx + dy * dy;
            if (d2 < linkDist2) {
              const alpha = (1 - d2 / linkDist2) * 0.18;
              ctx.strokeStyle = COLOR_LINK + alpha.toFixed(3) + ')';
              ctx.lineWidth = 0.6;
              ctx.beginPath();
              ctx.moveTo(a.x, a.y);
              ctx.lineTo(b.x, b.y);
              ctx.stroke();
            }
          }
        }
      }

      // glow do mouse
      if (mouse.active && !isCoarsePointer) {
        const grd = ctx.createRadialGradient(mouse.x, mouse.y, 0, mouse.x, mouse.y, 140);
        grd.addColorStop(0, COLOR_GLOW + '0.18)');
        grd.addColorStop(0.5, COLOR_GLOW + '0.05)');
        grd.addColorStop(1, COLOR_GLOW + '0)');
        ctx.fillStyle = grd;
        ctx.fillRect(mouse.x - 140, mouse.y - 140, 280, 280);
      }

      requestAnimationFrame(step);
    }

    function onMove(e) {
      const t = e.touches && e.touches[0];
      const x = t ? t.clientX : e.clientX;
      const y = t ? t.clientY : e.clientY;
      mouse.x = x;
      mouse.y = y;
      mouse.active = true;
    }

    function onLeave() {
      mouse.active = false;
      mouse.x = -9999;
      mouse.y = -9999;
    }

    function onVisibility() {
      if (document.hidden) {
        running = false;
      } else if (!running) {
        running = true;
        lastFrame = performance.now();
        requestAnimationFrame(step);
      }
    }

    resize();
    window.addEventListener('resize', resize, { passive: true });
    if (!isCoarsePointer) {
      window.addEventListener('mousemove', onMove, { passive: true });
      window.addEventListener('mouseleave', onLeave, { passive: true });
    }
    document.addEventListener('visibilitychange', onVisibility);

    if (reduceMotion) {
      // desenha apenas um frame estático
      step(performance.now());
      running = false;
    } else {
      lastFrame = performance.now();
      requestAnimationFrame(step);
    }
  })();
</script>
