---
import { url } from '../lib/url';

interface Props {
  /** Tamanho do título (ex: 'compact' = mais discreto). */
  size?: 'default' | 'compact';
}

const { size = 'default' } = Astro.props;
const mapHref =
  'https://www.google.com/maps/d/u/0/edit?mid=1QD2Eo26T_0l1PVMyjjRppfA9QbAl3-Q&usp=sharing';
---

<a
  href={mapHref}
  target="_blank"
  rel="noopener noreferrer"
  class={`map-cta ${size === 'compact' ? 'map-cta--compact' : ''}`}
  aria-label="Abrir mapa global do Control Team em nova aba"
>
  <video
    src={url('/video/hero.mp4')}
    poster={url('/video/hero-poster.jpg')}
    autoplay
    muted
    loop
    playsinline
    preload="metadata"
    class="map-cta__video"
  ></video>

  <div class="map-cta__overlay" aria-hidden="true"></div>

  <div class="map-cta__inner">
    <span class="map-cta__eyebrow bracket-label">// Mapa global</span>
    <span class="map-cta__title">Clique para visualizar a presença global do clã</span>
    <span class="map-cta__action">Abrir mapa <span aria-hidden="true">↗</span></span>
  </div>
</a>

<style>
  .map-cta {
    position: relative;
    display: block;
    margin: 0 auto;
    max-width: 64rem;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    border: 1px solid var(--color-border-subtle);
    background: var(--color-surface);
  }
  .map-cta:focus-visible {
    outline: 2px solid var(--color-accent-tactical);
    outline-offset: 2px;
  }
  .map-cta__video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.7s ease;
  }
  .map-cta:hover .map-cta__video {
    transform: scale(1.02);
  }
  .map-cta__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(5, 8, 8, 0.85), rgba(5, 8, 8, 0.35) 60%, rgba(5, 8, 8, 0.2));
  }
  .map-cta__inner {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.85rem;
    padding: 1rem 1.5rem;
    text-align: center;
  }
  .map-cta__eyebrow {
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.4em;
    font-size: 0.625rem;
    color: var(--color-accent-tactical);
  }
  .map-cta__title {
    font-family: var(--font-display);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.01em;
    color: var(--color-text-primary);
    font-size: clamp(0.85rem, 2.4vw, 1.875rem);
    white-space: nowrap;
  }
  .map-cta--compact .map-cta__title {
    font-size: clamp(0.8rem, 2.1vw, 1.5rem);
  }
  @media (max-width: 380px) {
    .map-cta__title { white-space: normal; font-size: 0.95rem; }
  }
  .map-cta__action {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.625rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--color-text-secondary);
    opacity: 0.85;
    transition: opacity 0.2s ease, color 0.2s ease;
  }
  .map-cta:hover .map-cta__action {
    opacity: 1;
    color: var(--color-accent-tactical);
  }
</style>
