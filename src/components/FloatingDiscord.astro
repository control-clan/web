---
import { site } from '../data/site';
---

<a
  href={site.social.discord}
  target="_blank"
  rel="noopener noreferrer"
  class="floating-discord"
  aria-label="Entrar no Discord do Control Team"
>
  <span class="floating-discord__pulse" aria-hidden="true"></span>
  <span class="floating-discord__icon" aria-hidden="true">
    <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
      <path d="M20.317 4.37a19.79 19.79 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028c.462-.63.873-1.295 1.226-1.994a.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.099.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/>
    </svg>
  </span>
  <span class="floating-discord__label">Entrar no Discord</span>
</a>

<style>
  .floating-discord {
    position: fixed;
    right: 18px;
    bottom: 18px;
    z-index: 60;
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.85rem 1.1rem;
    border-radius: 999px;
    background: var(--color-accent-tactical, #8fad3a);
    color: var(--color-base, #0a0d10);
    font-family: var(--font-display, 'Rajdhani', sans-serif);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-size: 0.875rem;
    text-decoration: none;
    box-shadow: 0 6px 24px rgba(0, 0, 0, 0.5), 0 0 24px rgba(140, 198, 63, 0.45);
    transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
    isolation: isolate;
  }

  .floating-discord:hover {
    background: var(--color-accent-tactical-dim, #6e8a22);
    transform: translateY(-2px) scale(1.02);
    box-shadow: 0 10px 32px rgba(0, 0, 0, 0.6), 0 0 36px rgba(140, 198, 63, 0.7);
  }

  .floating-discord__pulse {
    position: absolute;
    inset: -4px;
    border-radius: 999px;
    background: var(--color-accent-tactical, #8fad3a);
    opacity: 0.45;
    z-index: -1;
    animation: floating-pulse 2.2s ease-out infinite;
  }

  .floating-discord__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  @keyframes floating-pulse {
    0% { transform: scale(1); opacity: 0.5; }
    80% { transform: scale(1.35); opacity: 0; }
    100% { transform: scale(1.35); opacity: 0; }
  }

  /* Mobile: ícone só (sem texto), menor */
  @media (max-width: 640px) {
    .floating-discord {
      padding: 0.75rem;
      right: 14px;
      bottom: 14px;
    }
    .floating-discord__label {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .floating-discord__pulse { animation: none; }
    .floating-discord:hover { transform: none; }
  }
</style>
