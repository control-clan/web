---
import { site } from '../data/site';
import { url } from '../lib/url';

const year = new Date().getFullYear();

const socialLinks = [
  { label: 'Discord', href: site.social.discord },
  { label: 'Instagram', href: site.social.instagram },
  { label: 'YouTube', href: site.social.youtube },
  { label: 'WhatsApp', href: site.social.whatsapp },
];
---

<footer class="border-t border-border-subtle bg-base/85 backdrop-blur-sm">
  <div class="mx-auto grid max-w-6xl gap-10 px-6 py-12 md:grid-cols-3">
    <div>
      <div class="flex items-center gap-3">
        <img
          src={url('/brand/logo-ctrl.webp')}
          alt=""
          width="40"
          height="40"
          class="h-10 w-10"
          aria-hidden="true"
        />
        <p class="font-display text-2xl font-bold tracking-widest text-text-primary">CTRL</p>
      </div>
      <p class="mt-3 text-sm text-text-secondary">{site.tagline}</p>
    </div>

    <nav aria-label="Rodapé">
      <p class="font-mono text-[10px] uppercase tracking-[0.3em] text-accent-tactical bracket-label">
        Navegação
      </p>
      <ul class="mt-4 space-y-2">
        {
          site.nav.map((item) => (
            <li>
              <a
                href={url(item.href)}
                class="text-sm text-text-secondary transition-colors hover:text-accent-tactical"
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <div>
      <p class="font-mono text-[10px] uppercase tracking-[0.3em] text-accent-tactical bracket-label">
        Canais
      </p>
      <ul class="mt-4 space-y-2">
        {
          socialLinks.map((item) => (
            <li>
              <a
                href={item.href}
                target="_blank"
                rel="noopener noreferrer"
                class="text-sm text-text-secondary transition-colors hover:text-accent-tactical"
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </div>

  <div class="border-t border-border-subtle">
    <div class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-2 px-6 py-4 text-xs text-text-muted md:flex-row">
      <p class="font-mono uppercase tracking-widest">© {year} Control Team</p>
      <p class="font-mono uppercase tracking-widest">{site.tagline}</p>
    </div>
  </div>
</footer>
