---
import { site } from '../data/site';

type Stat = {
  code: string;
  label: string;
  value: string;
  href?: string;
};

const stats: Stat[] = [
  { code: '01', label: 'Games ativos', value: 'SQUAD · ARMA 3 · BELLUM' },
  { code: '02', label: 'Canal de comunicação', value: 'DISCORD', href: site.social.discord },
  {
    code: '03',
    label: 'Horário de operação',
    value: 'SEG–SEX APÓS 17:00 · FIM DE SEMANA INTEGRAL',
  },
];
---

<section class="relative border border-border-subtle bg-surface">
  <div class="border-b border-border-subtle px-6 py-3 flex items-center justify-between">
    <span class="font-mono text-[10px] uppercase tracking-[0.4em] text-accent-tactical bracket-label">
      Status
    </span>
    <span class="flex items-center gap-2 font-mono text-[10px] uppercase tracking-widest text-text-muted">
      <span class="inline-block h-2 w-2 animate-pulse rounded-full bg-accent-tactical"></span>
      Em operação
    </span>
  </div>
  <div class="grid grid-cols-1 gap-px bg-border-subtle md:grid-cols-3">
    {
      stats.map((s) => (
        <div class="flex flex-col gap-2 bg-surface p-6">
          <span class="font-mono text-[10px] text-text-muted">{`// ${s.code}`}</span>
          <span class="font-mono text-[10px] uppercase tracking-widest text-text-secondary">
            {s.label}
          </span>
          {s.href ? (
            <a
              href={s.href}
              target="_blank"
              rel="noopener noreferrer"
              class="group inline-flex items-center gap-2 font-display text-lg font-semibold uppercase tracking-wide text-text-primary transition-colors hover:text-accent-tactical"
            >
              <span>{s.value}</span>
              <span
                class="font-mono text-[10px] text-accent-tactical opacity-70 transition-opacity group-hover:opacity-100"
                aria-hidden="true"
              >
                ↗
              </span>
            </a>
          ) : (
            <span class="font-display text-lg font-semibold uppercase tracking-wide text-text-primary">
              {s.value}
            </span>
          )}
        </div>
      ))
    }
  </div>
</section>
