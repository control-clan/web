---
import { site } from '../data/site';

/**
 * Feed do Instagram via Behold.so
 * Widget configurado para @controlteam.br — busca os últimos posts automaticamente.
 * Para trocar a conta ou desativar, edite/remova o feed-id abaixo.
 */
const BEHOLD_FEED_ID = 'hVkRXXtSekdPxR48ERdq';
---

<div class="ig-feed">
  <behold-widget feed-id={BEHOLD_FEED_ID}></behold-widget>

  <div class="ig-feed__follow">
    <a
      href={site.social.instagram}
      target="_blank"
      rel="noopener noreferrer"
      class="ig-feed__follow-btn"
    >
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
        <rect x="3" y="3" width="18" height="18" rx="5" ry="5" />
        <path d="M17 7h.01" />
        <circle cx="12" cy="12" r="4" />
      </svg>
      <span>Seguir @controlteam.br</span>
    </a>
  </div>
</div>

<script is:inline>
  (() => {
    if (window.__beholdLoaded) return;
    window.__beholdLoaded = true;
    const s = document.createElement('script');
    s.type = 'module';
    s.src = 'https://w.behold.so/widget.js';
    document.head.appendChild(s);
  })();
</script>

<style>
  .ig-feed {
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
    align-items: stretch;
  }
  /* Container do widget Behold — mantém respiro e visual de borda tática */
  .ig-feed behold-widget {
    display: block;
    width: 100%;
  }

  .ig-feed__follow {
    display: flex;
    justify-content: center;
  }
  .ig-feed__follow-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.85rem 1.5rem;
    border-radius: 2px;
    border: 1px solid var(--color-border-subtle);
    background: var(--color-surface);
    color: var(--color-text-primary);
    font-family: var(--font-display);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    font-size: 0.875rem;
    text-decoration: none;
    transition: border-color 0.2s ease, color 0.2s ease;
  }
  .ig-feed__follow-btn:hover {
    border-color: var(--color-accent-tactical);
    color: var(--color-accent-tactical);
  }
</style>
